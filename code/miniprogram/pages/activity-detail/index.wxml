<view class="page-shell">
  <view class="topbar">
    <view class="brand-row">
      <view class="brand-pin"></view>
      <text class="brand-text">兰州美食</text>
    </view>
  </view>

  <view class="activity-detail" wx:if="{{activity}}">
    <image src="{{activity.coverImage}}" class="detail-cover" mode="aspectFill" />
    <view class="detail-body section-block">
      <text class="pill pill-secondary">{{activity.type === 'lecture' ? '讲座' : '活动'}}</text>
      <text class="detail-title">{{activity.title}}</text>
      <view class="detail-info-row">
        <text class="detail-info">开始：{{activity.startTime}}</text>
        <text class="detail-info">结束：{{activity.endTime}}</text>
      </view>
      <view class="detail-info-row" wx:if="{{activity.location || activity.speaker}}">
        <text class="detail-info" wx:if="{{activity.location}}">地点：{{activity.location}}</text>
        <text class="detail-info" wx:if="{{activity.speaker}}">主讲：{{activity.speaker}}</text>
      </view>
      <view class="detail-info-row" wx:if="{{activity.signupDeadline || activity.capacity}}">
        <text class="detail-info" wx:if="{{activity.signupDeadline}}">截止：{{activity.signupDeadline}}</text>
        <text class="detail-info" wx:if="{{activity.capacity}}">名额：{{activity.capacity}} 人</text>
      </view>
      <text class="detail-brief">{{activity.brief}}</text>
      <text class="detail-desc">{{activity.description || activity.brief}}</text>
    </view>

    <view class="floating-bar">
      <view class="floating-actions">
        <view class="ghost-btn" bindtap="goToShare">分享</view>
        <view class="primary-btn" bindtap="goToSignUp">立即报名</view>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="modal" wx:if="{{showSignupModal}}" catchtap="hideSignupModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">活动报名</text>
        <view class="modal-close" bindtap="hideSignupModal">×</view>
      </view>

      <view class="form-group">
        <text class="form-label">姓名 *</text>
        <input class="form-input" value="{{signupForm.name}}" placeholder="请输入您的姓名" bindinput="onFormInput" data-field="name"/>
      </view>

      <view class="form-group">
        <text class="form-label">手机号 *</text>
        <input class="form-input" type="number" value="{{signupForm.phone}}" placeholder="请输入手机号" bindinput="onFormInput" data-field="phone"/>
      </view>

      <view class="form-group">
        <text class="form-label">备注</text>
        <textarea class="form-textarea" value="{{signupForm.remark}}" placeholder="请输入备注（选填）" bindinput="onFormInput" data-field="remark"/>
      </view>

      <view class="form-actions">
        <view class="btn-cancel" bindtap="hideSignupModal">取消</view>
        <view class="btn-confirm" bindtap="submitSignup">提交报名</view>
      </view>
    </view>
  </view>
</view>
