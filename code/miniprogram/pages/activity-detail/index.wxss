.detail-cover {
  width: 100%;
  height: 500rpx;
}

.detail-body {
  padding-bottom: 160rpx;
}

.detail-title {
  display: block;
  margin-top: 16rpx;
  color: var(--color-text);
  font-size: 52rpx;
  font-style: italic;
  font-weight: 700;
  line-height: 1.1;
}

.detail-info-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.detail-info {
  color: var(--color-secondary);
  font-size: 22rpx;
  font-weight: 700;
}

.detail-brief {
  display: block;
  margin-top: 28rpx;
  color: var(--color-text-soft);
  font-size: 26rpx;
  line-height: 1.7;
}

.detail-desc {
  display: block;
  margin-top: 32rpx;
  color: var(--color-text-soft);
  font-size: 28rpx;
  line-height: 1.8;
}

.floating-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(250,249,248,0.94);
}

.floating-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.ghost-btn,
.primary-btn {
  padding: 18rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.ghost-btn {
  background: var(--color-surface-low);
  color: var(--color-text);
}

.primary-btn {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
}

.loading {
  padding: 80rpx 0;
  text-align: center;
  color: var(--color-text-soft);
}

/* 报名弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #fff;
  border-radius: 16rpx;
  width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
  padding: 32rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
}

.form-textarea {
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 120rpx;
}

.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: #822b17;
  color: #fff;
}