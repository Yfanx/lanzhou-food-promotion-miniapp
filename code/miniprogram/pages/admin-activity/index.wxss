.admin-activity {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.add-btn {
  background: #d5322a;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.activity-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
}

.activity-image {
  width: 180rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #eee;
}

.activity-info {
  flex: 1;
}

.activity-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.activity-time, .activity-location {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.activity-status {
  margin-top: 12rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background: #eee;
  color: #666;
}

.status-0 { background: #fff3e0; color: #ff9800; }
.status-1 { background: #e8f5e9; color: #4caf50; }
.status-2 { background: #f5f5f5; color: #999; }

.activity-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.empty-state, .loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.form-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.form-container {
  width: 650rpx;
  max-height: 80vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.form-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-input {
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.image-picker {
  width: 200rpx;
  height: 120rpx;
  border: 2px dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
}

.image-picker image {
  width: 100%;
  height: 100%;
}

.picker-value {
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.form-actions button {
  flex: 1;
}
