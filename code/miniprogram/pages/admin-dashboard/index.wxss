.admin-dashboard {
  min-height: 100vh;
  background: linear-gradient(180deg, #d5322a 0%, #b5291f 100%);
  padding-bottom: 40rpx;
}

.dashboard-header {
  padding: 60rpx 40rpx 80rpx;
  color: #fff;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 12rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 32rpx;
  margin-top: -40rpx;
}

.stat-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.stat-number {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #d5322a;
}

.stat-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.menu-section {
  margin-top: 48rpx;
  padding: 0 32rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.menu-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 16rpx;
  text-align: center;
}

.menu-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.menu-text {
  display: block;
  font-size: 24rpx;
  color: #333;
}
