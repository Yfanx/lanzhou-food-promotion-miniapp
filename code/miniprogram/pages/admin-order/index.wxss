.admin-order {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx;
}

.page-header {
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.filter-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  overflow-x: auto;
}

.filter-tab {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background: #fff;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}

.filter-tab.active {
  background: #d5322a;
  color: #fff;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-no {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.order-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.status-0 { background: #fff3e0; color: #ff9800; }
.status-1 { background: #e3f2fd; color: #2196f3; }
.status-2 { background: #e8f5e9; color: #4caf50; }
.status--1 { background: #f5f5f5; color: #999; }

.order-foods {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1px solid #f0f0f0;
}

.order-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #d5322a;
}

.order-actions {
  display: flex;
  gap: 12rpx;
}

.empty-state, .loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  padding: 32rpx 0;
  color: #d5322a;
  font-size: 28rpx;
}
