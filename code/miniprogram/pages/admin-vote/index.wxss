.admin-vote {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.add-btn {
  background: #d5322a;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
}

.vote-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.vote-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
}

.vote-info {
  flex: 1;
}

.vote-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.vote-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.vote-end {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.vote-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.option-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  color: #666;
}

.vote-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.empty-state, .loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.form-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.form-container {
  width: 650rpx;
  max-height: 80vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.form-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-input {
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.option-list {
  margin-bottom: 16rpx;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.remove-option {
  color: #d5322a;
  font-size: 32rpx;
  padding: 0 12rpx;
}

.add-option {
  display: flex;
  gap: 12rpx;
}

.add-option input {
  flex: 1;
}

.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.form-actions button {
  flex: 1;
}
