<view class="page-shell">
  <view class="topbar">
    <view class="brand-row">
      <view class="brand-pin"></view>
      <text class="brand-text">兰州美食</text>
    </view>
  </view>

  <view class="notice-detail section-block" wx:if="{{announcement}}">
    <view class="notice-header">
      <text class="pill pill-secondary" wx:if="{{announcement.isTop}}">置顶</text>
      <text class="notice-title">{{announcement.title}}</text>
    </view>
    <text class="notice-time">{{announcement.createTime}}</text>
    <text class="notice-content">{{announcement.content || announcement.brief}}</text>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
