<view class="page-shell">
  <view class="topbar">
    <view class="brand-row">
      <view class="brand-pin"></view>
      <text class="brand-text">兰州美食</text>
    </view>
  </view>

  <view class="section-block">
    <text class="eyebrow">NOTICE</text>
    <text class="section-title">平台公告</text>
  </view>

  <view class="notice-list">
    <view class="notice-card card" wx:for="{{announcements}}" wx:key="_id">
      <view class="notice-row">
        <text class="pill pill-secondary" wx:if="{{item.isTop}}">置顶</text>
        <text class="notice-title">{{item.title}}</text>
      </view>
      <text class="notice-brief">{{item.brief}}</text>
      <text class="notice-time">{{item.createTime}}</text>
    </view>
  </view>
</view>
