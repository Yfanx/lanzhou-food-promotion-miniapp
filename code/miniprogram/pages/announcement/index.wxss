.notice-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.notice-card {
  padding: 28rpx;
}

.notice-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.notice-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-style: italic;
  font-weight: 700;
}

.notice-brief {
  display: block;
  margin-top: 14rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
  line-height: 1.7;
}

.notice-time {
  display: block;
  margin-top: 18rpx;
  color: #8f7973;
  font-size: 18rpx;
}
