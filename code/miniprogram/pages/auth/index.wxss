.auth-page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 48rpx 28rpx 64rpx;
  box-sizing: border-box;
}

.auth-header {
  padding: 20rpx 8rpx 36rpx;
}

.brand-row {
  display: flex;
  align-items: center;
}

.brand-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #e9ecf4;
  flex-shrink: 0;
}

.brand-copy {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.brand-title {
  font-size: 36rpx;
  line-height: 1.2;
  color: #1f2329;
  font-weight: 700;
}

.brand-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #86909c;
}

.auth-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx 36rpx;
  box-shadow: 0 12rpx 36rpx rgba(31, 35, 41, 0.06);
}

.auth-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.3;
  color: #1f2329;
  font-weight: 700;
}

.auth-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #4e5969;
}

.auth-primary,
.auth-secondary,
.auth-danger {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-primary {
  margin-top: 36rpx;
  background: #07c160;
  color: #ffffff;
  border: none;
}

.auth-secondary {
  margin-top: 20rpx;
  background: #f7f8fa;
  color: #1f2329;
  border: 2rpx solid #e5e6eb;
}

.field-group {
  margin-top: 32rpx;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #4e5969;
}

.auth-input {
  width: 100%;
  height: 88rpx;
  border-radius: 18rpx;
  background: #f7f8fa;
  border: 2rpx solid #e5e6eb;
  box-sizing: border-box;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1f2329;
}

.auth-danger {
  margin-top: 20rpx;
  background: #e64545;
  color: #ffffff;
  border: none;
}

.auth-tip {
  display: block;
  margin-top: 28rpx;
  text-align: center;
  font-size: 22rpx;
  color: #86909c;
}
