<view class="page-shell category-page">
  <view class="topbar">
    <view class="brand-row">
      <view class="brand-pin"></view>
      <text class="brand-text">兰州美食</text>
    </view>
  </view>

  <view class="section-block">
    <text class="eyebrow">DISCOVER</text>
    <text class="section-title">分类选食</text>
  </view>

  <view class="tabs-row section-block">
    <view class="tab-chip {{!selectedCategory ? 'tab-chip-active' : ''}}" bindtap="selectAll">全部</view>
    <view class="tab-chip {{selectedCategory === item._id ? 'tab-chip-active' : ''}}" wx:for="{{categories}}" wx:key="_id" data-id="{{item._id}}" bindtap="selectCategory">
      {{item.name}}
    </view>
  </view>

  <view class="food-list">
    <view class="food-card card" wx:for="{{foods}}" wx:key="_id" bindtap="goToFoodDetail" data-id="{{item._id}}">
      <image src="{{item.coverImage}}" class="food-card-image" mode="aspectFill" />
      <view class="food-card-body">
        <text class="food-card-title">{{item.name}}</text>
        <text class="food-card-brief">{{item.brief}}</text>
        <text class="food-card-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>
</view>
