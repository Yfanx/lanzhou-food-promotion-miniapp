.detail-hero {
  position: relative;
  height: 560rpx;
}

.detail-hero-image {
  width: 100%;
  height: 100%;
}

.detail-hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(26,28,28,0.1) 0%, rgba(26,28,28,0.72) 100%);
}

.detail-hero-body {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx;
}

.detail-hero-title {
  display: block;
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 52rpx;
  line-height: 1.1;
  font-style: italic;
  font-weight: 700;
}

.detail-content {
  padding-bottom: 60rpx;
}

.detail-section-title {
  display: block;
  color: var(--color-text);
  font-size: 48rpx;
  font-style: italic;
  font-weight: 700;
  line-height: 1.15;
}

.detail-meta {
  display: block;
  margin-top: 16rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
}

.detail-text {
  display: block;
  margin-top: 32rpx;
  color: var(--color-text-soft);
  font-size: 28rpx;
  line-height: 1.8;
}

.related-doc {
  overflow: hidden;
}

.related-doc-image {
  width: 100%;
  height: 280rpx;
}

.related-doc-body {
  padding: 24rpx;
}

.related-doc-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.related-doc-tag,
.related-doc-duration {
  color: var(--color-secondary);
  font-size: 20rpx;
  font-weight: 700;
}

.related-doc-title {
  display: block;
  margin-top: 12rpx;
  color: var(--color-text);
  font-size: 34rpx;
  font-style: italic;
  font-weight: 700;
}

.related-doc-brief {
  display: block;
  margin-top: 12rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
  line-height: 1.7;
}

.related-doc-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 18rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}

.loading {
  padding: 80rpx 0;
  text-align: center;
  color: var(--color-text-soft);
}
