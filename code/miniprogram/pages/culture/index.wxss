.culture-hero {
  position: relative;
  height: 720rpx;
}

.culture-hero-image {
  width: 100%;
  height: 100%;
}

.culture-hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(26, 28, 28, 0.05) 0%, rgba(26, 28, 28, 0.7) 100%);
}

.culture-hero-body {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx;
}

.culture-hero-title {
  display: block;
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 58rpx;
  line-height: 1.08;
  font-style: italic;
  font-weight: 700;
}

.culture-hero-desc {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
  line-height: 1.7;
}

.tabs-row {
  display: flex;
  gap: 16rpx;
  overflow-x: scroll;
  white-space: nowrap;
}

.tab-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: var(--color-surface-strong);
  color: var(--color-text-soft);
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.tab-chip-active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
}

.culture-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.culture-card-item {
  display: flex;
  overflow: hidden;
}

.culture-card-image {
  width: 240rpx;
  height: 220rpx;
  flex-shrink: 0;
}

.culture-card-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  padding: 26rpx;
}

.culture-card-meta {
  color: var(--color-secondary);
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.culture-card-title {
  margin-top: 8rpx;
  color: var(--color-text);
  font-size: 34rpx;
  line-height: 1.2;
  font-style: italic;
  font-weight: 700;
}

.culture-card-brief {
  margin-top: 12rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
  line-height: 1.65;
}

.culture-card-time {
  margin-top: 14rpx;
  color: #8a746d;
  font-size: 18rpx;
}

.culture-feature-card {
  padding: 34rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
}

.culture-feature-eyebrow {
  display: block;
  margin-bottom: 10rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.culture-feature-title {
  display: block;
  font-size: 44rpx;
  line-height: 1.18;
  font-style: italic;
  font-weight: 700;
}

.culture-feature-btn {
  display: inline-flex;
  margin-top: 24rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(253, 187, 36, 0.92);
  color: #5d4200;
  font-size: 22rpx;
  font-weight: 800;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  color: var(--color-text-soft);
}
