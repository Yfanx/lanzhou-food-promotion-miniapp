.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 0 20rpx;
}

.fav-card {
  display: flex;
}

.fav-image {
  width: 200rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.fav-body {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.fav-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-style: italic;
  font-weight: 700;
}

.fav-tag {
  color: var(--color-secondary);
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.fav-brief {
  margin-top: 10rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.fav-link {
  margin-top: 14rpx;
  color: var(--color-primary);
  font-size: 20rpx;
  font-weight: 700;
}

.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.prompt-text {
  color: var(--color-text-soft);
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.prompt-btn {
  padding: 24rpx 48rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.empty,
.loading {
  padding: 80rpx 0;
  text-align: center;
  color: var(--color-text-soft);
}
