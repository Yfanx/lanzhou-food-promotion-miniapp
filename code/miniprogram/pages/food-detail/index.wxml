<view class="detail-page" wx:if="{{!loading && food}}">
  <view class="detail-hero">
    <swiper class="detail-swiper" indicator-dots circular autoplay>
      <swiper-item wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" class="detail-image" mode="aspectFill" bindtap="previewImage" data-src="{{item}}" />
      </swiper-item>
    </swiper>
    <view class="detail-overlay">
      <text class="pill pill-secondary">传统非遗</text>
      <text class="detail-title">{{food.name}}</text>
      <text class="detail-brief">{{food.brief}}</text>
    </view>
  </view>

  <view class="detail-shell">
    <view class="detail-card intro-card">
      <view class="price-line">
        <text class="detail-price">城市风味名片</text>
        <text class="detail-origin">{{food.categoryName}}</text>
      </view>
      <view class="meta-line">
        <text>专题分类 {{food.categoryName}}</text>
        <text>适合用于宣传展示</text>
        <text>可衔接体验路线</text>
      </view>
    </view>

    <view class="detail-card">
      <text class="detail-section-title">历史与文化</text>
      <text class="detail-section-text">{{food.description ? '' : food.brief}}</text>
      <rich-text wx:if="{{food.description}}" nodes="{{food.description}}"></rich-text>
    </view>

    <view class="detail-card">
      <text class="detail-section-title">食材与制作</text>
      <view class="ingredient-grid">
        <view class="ingredient-item">
          <text class="ingredient-tag">手工拉制</text>
          <text class="ingredient-text">保留面条延展感与筋道口感，是展示技艺的重要切口。</text>
        </view>
        <view class="ingredient-item">
          <text class="ingredient-tag">老汤慢熬</text>
          <text class="ingredient-text">清亮汤底更适合在图文与视频里体现兰州风味层次。</text>
        </view>
        <view class="ingredient-item">
          <text class="ingredient-tag">灵魂辣子</text>
          <text class="ingredient-text">色泽与香气共同构成这道地方风味的视觉记忆点。</text>
        </view>
        <view class="ingredient-item">
          <text class="ingredient-tag">鲜香点缀</text>
          <text class="ingredient-text">香菜与白萝卜让整体呈现更完整，也更利于宣传表达。</text>
        </view>
      </view>
    </view>

    <view class="detail-card">
      <text class="detail-section-title">食客评价</text>
      <view class="review-item" wx:for="{{reviews}}" wx:key="name">
        <view class="review-head">
          <text class="review-name">{{item.name}}</text>
          <text class="review-score">{{item.score}}</text>
        </view>
        <text class="review-text">{{item.text}}</text>
      </view>
    </view>

    <view class="detail-card">
      <text class="detail-section-title">线下体验点位</text>
      <view class="store-item" wx:for="{{nearbyStores}}" wx:key="name">
        <view class="store-copy">
          <text class="store-name">{{item.name}}</text>
          <text class="store-meta">{{item.distance}} · {{item.status}}</text>
        </view>
        <view class="store-btn">{{item.cta}}</view>
      </view>
    </view>
  </view>

  <view class="floating-bar">
    <view class="floating-price">
      <text class="floating-label">浏览路径</text>
      <text class="floating-amount">{{food.categoryName}}</text>
    </view>
    <view class="floating-actions">
      <view class="ghost-btn" bindtap="goToShare">分享专题</view>
      <view class="ghost-btn" bindtap="goToVote">参与投票</view>
      <view class="primary-btn" bindtap="goToGroupBuy">查看体验组合</view>
    </view>
  </view>
</view>

<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>
