.detail-page {
  min-height: 100vh;
  background: var(--color-surface);
  padding-bottom: 180rpx;
}

.detail-hero {
  position: relative;
}

.detail-swiper {
  height: 760rpx;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 36rpx 28rpx 42rpx;
  background: linear-gradient(180deg, rgba(26, 28, 28, 0) 0%, rgba(26, 28, 28, 0.82) 100%);
}

.detail-title {
  display: block;
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 66rpx;
  line-height: 1.04;
  font-style: italic;
  font-weight: 700;
}

.detail-brief {
  display: block;
  width: 82%;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
  line-height: 1.7;
}

.detail-shell {
  padding: 24rpx;
}

.detail-card {
  margin-bottom: 18rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: var(--color-surface-card);
  box-shadow: var(--shadow-soft);
}

.intro-card {
  margin-top: -24rpx;
  position: relative;
  z-index: 2;
}

.price-line {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}

.detail-price {
  color: var(--color-primary);
  font-size: 54rpx;
  font-style: italic;
  font-weight: 700;
}

.detail-origin {
  color: #9d8c87;
  font-size: 26rpx;
  text-decoration: line-through;
}

.meta-line {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 18rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
}

.detail-section-title {
  display: block;
  margin-bottom: 20rpx;
  color: var(--color-text);
  font-size: 42rpx;
  font-style: italic;
  font-weight: 700;
}

.detail-section-text,
rich-text {
  color: var(--color-text-soft);
  font-size: 24rpx;
  line-height: 1.8;
}

.ingredient-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.ingredient-item {
  width: calc(50% - 8rpx);
  min-height: 150rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: var(--color-surface-low);
}

.ingredient-tag {
  display: inline-block;
  margin-bottom: 10rpx;
  color: var(--color-primary);
  font-size: 20rpx;
  font-weight: 800;
}

.ingredient-text {
  display: block;
  color: var(--color-text-soft);
  font-size: 22rpx;
  line-height: 1.7;
}

.review-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--color-outline);
}

.review-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.review-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.review-name {
  color: var(--color-text);
  font-size: 24rpx;
  font-weight: 700;
}

.review-score {
  color: var(--color-secondary);
  font-size: 22rpx;
  font-weight: 800;
}

.review-text {
  color: var(--color-text-soft);
  font-size: 22rpx;
  line-height: 1.7;
}

.store-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--color-outline);
}

.store-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.store-name {
  display: block;
  color: var(--color-text);
  font-size: 26rpx;
  font-weight: 700;
}

.store-meta {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-soft);
  font-size: 20rpx;
}

.store-btn {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
}

.floating-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 16rpx;
  border-radius: 999rpx;
  background: rgba(250, 249, 248, 0.94);
  box-shadow: var(--shadow-soft);
}

.floating-price {
  padding-left: 18rpx;
}

.floating-label {
  display: block;
  color: var(--color-text-soft);
  font-size: 18rpx;
}

.floating-amount {
  display: block;
  color: var(--color-primary);
  font-size: 34rpx;
  font-style: italic;
  font-weight: 700;
}

.floating-actions {
  display: flex;
  gap: 12rpx;
}

.ghost-btn,
.primary-btn {
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.ghost-btn {
  background: var(--color-surface-low);
  color: var(--color-text);
}

.primary-btn {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
}

.loading {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-soft);
}
