<view class="page-shell home-page">
  <view class="topbar">
    <view class="brand-row">
      <view class="brand-pin"></view>
      <text class="brand-text">兰州美食</text>
    </view>
    <view class="topbar-actions">
      <view class="icon-button">城</view>
      <view class="icon-button">宣</view>
    </view>
  </view>

  <view class="hero-card section-block">
    <swiper class="hero-swiper" indicator-dots autoplay circular>
      <swiper-item wx:for="{{banners}}" wx:key="_id">
        <view class="hero-slide">
          <image src="{{item.image}}" class="hero-image" mode="aspectFill" />
          <view class="hero-overlay">
            <text class="pill pill-secondary">城市宣传</text>
            <text class="hero-title">{{item.title || '兰州美食城市名片'}}</text>
            <text class="hero-desc">从一碗面、一道街巷烟火到手艺人的清晨劳作，把兰州味道组织成适合传播、答辩展示与文化阅读的城市故事。</text>
            <view class="hero-actions">
              <view class="hero-cta" bindtap="goToPromoPage">进入宣传专题</view>
              <view class="hero-ghost" bindtap="goToCulturePage">浏览文化档案</view>
            </view>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <view class="ticker section-block" bindtap="goToAnnouncement">
    <text class="ticker-label">动态</text>
    <text class="ticker-text">这里集中展示公告更新、专题策划、文化活动和线下体验的统一入口。</text>
    <text class="ticker-arrow">→</text>
  </view>

  <view class="section-block">
    <view class="section-head">
      <view>
        <text class="eyebrow">PROMOTION</text>
        <text class="section-title">城市宣传主线</text>
      </view>
      <text class="section-link" bindtap="goToPromoPage">查看专题</text>
    </view>
    <scroll-view class="promo-scroll" scroll-x enhanced show-scrollbar="false">
      <view class="promo-row">
        <view class="promo-card card" wx:for="{{promoFeatures}}" wx:key="_id" bindtap="goToPromoPage">
          <image src="{{item.image}}" class="promo-image" mode="aspectFill" />
          <view class="promo-body">
            <text class="pill pill-secondary">{{item.tag}}</text>
            <text class="promo-title">{{item.title}}</text>
            <text class="promo-desc">{{item.summary}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section-block">
    <view class="section-head">
      <view>
        <text class="eyebrow">FILMS</text>
        <text class="section-title">纪录片与宣传片推荐</text>
      </view>
      <text class="section-link" bindtap="goToPromoPage">进入片单</text>
    </view>
    <view class="doc-feed">
      <view class="doc-card card" wx:for="{{documentaries}}" wx:key="_id" bindtap="goToDocumentary" data-documentary-id="{{item._id}}" data-article-id="{{item.articleId}}" data-playable="{{item.playable}}">
        <image src="{{item.poster}}" class="doc-poster" mode="aspectFill" />
        <view class="doc-mask"></view>
        <view class="doc-body">
          <view class="doc-meta">
            <text class="doc-tag">{{item.category}}</text>
            <text class="doc-duration">{{item.duration}}</text>
          </view>
          <text class="doc-title">{{item.title}}</text>
          <text class="doc-desc">{{item.brief}}</text>
          <view class="doc-play-row">
            <view class="doc-play-btn">{{item.actionText || '查看对应内容'}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-block">
    <view class="section-head">
      <view>
        <text class="eyebrow">ARCHIVE</text>
        <text class="section-title">非遗技艺与城市记忆</text>
      </view>
      <text class="section-link" bindtap="goToCulturePage">进入内容中心</text>
    </view>

    <view class="featured-card card" wx:if="{{featuredStory}}" bindtap="goToStoryDetail" data-id="{{featuredStory._id}}">
      <image src="{{featuredStory.coverImage}}" class="featured-image" mode="aspectFill" />
      <view class="featured-body">
        <view class="featured-meta">
          <text class="pill pill-secondary">专题主稿</text>
          <text class="featured-type">{{featuredStory.createTime}}</text>
        </view>
        <text class="featured-title">{{featuredStory.title}}</text>
        <text class="featured-desc">{{featuredStory.brief}}</text>
      </view>
    </view>

    <view class="side-feed">
      <view class="side-card card" wx:for="{{archiveHighlights}}" wx:key="_id" bindtap="goToStoryDetail" data-id="{{item._id}}">
        <image src="{{item.coverImage}}" class="side-image" mode="aspectFill" />
        <view class="side-body">
          <text class="side-tag">文化档案</text>
          <text class="side-title">{{item.title}}</text>
          <text class="side-desc">{{item.brief}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section-block">
    <view class="section-head">
      <view>
        <text class="eyebrow">ROUTES</text>
        <text class="section-title">风味专题索引</text>
      </view>
      <text class="section-link" bindtap="goToFoodList">查看全部</text>
    </view>
    <view class="category-grid">
      <view class="category-card" wx:for="{{categories}}" wx:key="_id" bindtap="goToCategory" data-id="{{item._id}}">
        <image src="{{item.icon}}" class="category-image" mode="aspectFill" />
        <view class="category-mask"></view>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="culture-spot section-block">
    <view class="culture-card">
      <text class="culture-title">让小程序先讲故事，再承接功能</text>
      <text class="culture-desc">这一版首页把“宣传专题、文化档案、片单推荐、活动路线”作为主链路，团购与下单能力保留但降为次级入口，更符合“兰州美食文化宣传小程序”的答辩定位。</text>
      <view class="culture-btn" bindtap="goToPromoPage">查看宣传框架</view>
    </view>
  </view>

  <view class="section-block" wx:if="{{activities.length > 0}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">AGENDA</text>
        <text class="section-title">文化活动与体验路线</text>
      </view>
      <text class="section-link" bindtap="goToActivity">更多活动</text>
    </view>
    <view class="activity-stack">
      <view class="activity-card card" wx:for="{{activities}}" wx:key="_id" bindtap="goToActivity">
        <image src="{{item.coverImage}}" class="activity-image" mode="aspectFill" />
        <view class="activity-content">
          <text class="activity-name">{{item.title}}</text>
          <text class="activity-time">{{item.startTime}} - {{item.endTime}}</text>
          <text class="activity-brief">{{item.brief}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
