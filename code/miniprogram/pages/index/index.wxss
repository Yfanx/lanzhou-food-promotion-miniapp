.hero-card {
  border-radius: 32rpx;
  overflow: hidden;
}

.hero-swiper {
  height: 760rpx;
}

.hero-slide {
  position: relative;
  width: 100%;
  height: 100%;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 34rpx;
  background: linear-gradient(180deg, rgba(26, 28, 28, 0) 0%, rgba(26, 28, 28, 0.78) 100%);
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 64rpx;
  line-height: 1.05;
  font-style: italic;
  font-weight: 700;
}

.hero-desc {
  display: block;
  width: 78%;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
  line-height: 1.7;
}

.hero-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 18rpx 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.hero-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.ticker {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-card);
  background: var(--color-surface-low);
}

.ticker-label {
  flex-shrink: 0;
  color: var(--color-primary);
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.ticker-text {
  flex: 1;
  color: var(--color-text-soft);
  font-size: 22rpx;
}

.ticker-arrow {
  color: var(--color-primary);
  font-size: 32rpx;
}

.promo-scroll {
  width: 100%;
  white-space: nowrap;
}

.promo-row {
  display: inline-flex;
  gap: 18rpx;
  padding-right: 24rpx;
}

.promo-card {
  width: 530rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.promo-image {
  width: 100%;
  height: 260rpx;
}

.promo-body {
  padding: 24rpx;
}

.promo-title {
  display: block;
  margin-top: 14rpx;
  color: var(--color-text);
  font-size: 36rpx;
  font-style: italic;
  font-weight: 700;
  line-height: 1.15;
}

.promo-desc {
  display: block;
  margin-top: 10rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
  line-height: 1.7;
}

.doc-feed {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.doc-card {
  position: relative;
  min-height: 280rpx;
  overflow: hidden;
}

.doc-poster {
  width: 100%;
  height: 280rpx;
}

.doc-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(26, 28, 28, 0.08) 0%, rgba(26, 28, 28, 0.72) 100%);
}

.doc-body {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx;
}

.doc-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.doc-tag,
.doc-duration {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}

.doc-title {
  display: block;
  margin-top: 12rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-style: italic;
  font-weight: 700;
}

.doc-desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 22rpx;
  line-height: 1.6;
}

.doc-play-row {
  display: flex;
  margin-top: 16rpx;
}

.doc-play-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.category-card {
  position: relative;
  width: calc(50% - 9rpx);
  height: 220rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

.category-image {
  width: 100%;
  height: 100%;
}

.category-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(26, 28, 28, 0.12) 0%, rgba(26, 28, 28, 0.56) 100%);
}

.category-name {
  position: absolute;
  left: 22rpx;
  bottom: 22rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.featured-card {
  margin-bottom: 18rpx;
}

.featured-image {
  width: 100%;
  height: 420rpx;
}

.featured-body {
  padding: 28rpx;
  background: var(--color-surface-card);
}

.featured-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.featured-type {
  color: #8a746d;
  font-size: 20rpx;
  font-weight: 700;
}

.featured-title {
  display: block;
  color: var(--color-text);
  font-size: 42rpx;
  font-style: italic;
  font-weight: 700;
  line-height: 1.08;
}

.featured-desc {
  display: block;
  margin-top: 12rpx;
  color: var(--color-text-soft);
  font-size: 24rpx;
  line-height: 1.7;
}

.side-feed {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.side-card {
  display: flex;
  align-items: stretch;
}

.side-image {
  width: 230rpx;
  height: 190rpx;
  flex-shrink: 0;
}

.side-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  padding: 24rpx;
}

.side-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-style: italic;
  font-weight: 700;
}

.side-tag {
  color: var(--color-secondary);
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.side-desc {
  margin-top: 10rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
  line-height: 1.6;
}

.culture-card {
  padding: 40rpx 34rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
}

.culture-title {
  display: block;
  font-size: 52rpx;
  line-height: 1.1;
  font-style: italic;
  font-weight: 700;
}

.culture-desc {
  display: block;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
  line-height: 1.75;
}

.culture-btn {
  display: inline-flex;
  margin-top: 28rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(253, 187, 36, 0.92);
  color: #5d4200;
  font-size: 22rpx;
  font-weight: 800;
}

.activity-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.activity-card {
  display: flex;
  align-items: stretch;
}

.activity-image {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
}

.activity-content {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  padding: 24rpx;
}

.activity-name {
  color: var(--color-text);
  font-size: 34rpx;
  font-style: italic;
  font-weight: 700;
}

.activity-time {
  margin-top: 10rpx;
  color: var(--color-secondary);
  font-size: 20rpx;
  font-weight: 700;
}

.activity-brief {
  margin-top: 10rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
  line-height: 1.6;
}
