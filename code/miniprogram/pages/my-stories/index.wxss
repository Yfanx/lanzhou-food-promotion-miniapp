.stories-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 0 20rpx;
}

.story-card {
  padding: 28rpx;
}

.story-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.story-status {
  font-size: 22rpx;
  font-weight: 800;
}

.story-status.status-pass {
  color: #52c41a;
}

.story-status.status-pending {
  color: var(--color-secondary);
}

.story-time {
  color: var(--color-text-soft);
  font-size: 22rpx;
}

.story-content {
  display: block;
  color: var(--color-text);
  font-size: 28rpx;
  line-height: 1.7;
}

.story-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.story-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
}

.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.prompt-text {
  color: var(--color-text-soft);
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.prompt-btn {
  padding: 24rpx 48rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.empty,
.loading {
  padding: 80rpx 0;
  text-align: center;
  color: var(--color-text-soft);
}
