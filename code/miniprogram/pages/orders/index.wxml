<view class="page-shell">
  <view class="topbar">
    <view class="brand-row">
      <view class="brand-pin"></view>
      <text class="brand-text">兰州美食</text>
    </view>
  </view>

  <view class="section-block" wx:if="{{isLoggedIn}}">
    <text class="eyebrow">ORDERS</text>
    <text class="section-title">我的订单</text>
  </view>

  <view class="orders-list" wx:if="{{isLoggedIn && orders.length > 0}}">
    <view class="order-card card" wx:for="{{orders}}" wx:key="_id">
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <text class="order-status {{item.status === 3 ? 'status-done' : ''}}">{{statusMap[item.status]}}</text>
      </view>
      <view class="order-items">
        <view class="order-item" wx:for="{{item.foods}}" wx:for-item="food" wx:key="foodId">
          <text class="food-name">{{food.name}}</text>
          <text class="food-count">x{{food.count}}</text>
          <text class="food-price">¥{{food.price}}</text>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-total">合计：¥{{item.totalPrice}}</text>
        <text class="order-time">{{item.createTime}}</text>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{isLoggedIn && !loading && orders.length === 0}}">
    <text>暂无订单</text>
  </view>

  <view class="login-prompt section-block" wx:if="{{!isLoggedIn}}">
    <text class="prompt-text">登录后查看订单</text>
    <view class="prompt-btn" bindtap="goToLogin">立即登录</view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
