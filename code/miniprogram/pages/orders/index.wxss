.orders-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 0 20rpx;
}

.order-card {
  padding: 28rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-outline);
}

.order-no {
  color: var(--color-text-soft);
  font-size: 22rpx;
}

.order-status {
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 800;
}

.order-status.status-done {
  color: #52c41a;
}

.order-items {
  padding: 20rpx 0;
}

.order-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.order-item:last-child {
  margin-bottom: 0;
}

.food-name {
  flex: 1;
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 700;
}

.food-count {
  color: var(--color-text-soft);
  font-size: 22rpx;
}

.food-price {
  color: var(--color-primary);
  font-size: 20rpx;
  font-weight: 800;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-outline);
}

.order-total {
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 700;
}

.order-time {
  color: var(--color-text-soft);
  font-size: 22rpx;
}

.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.prompt-text {
  color: var(--color-text-soft);
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.prompt-btn {
  padding: 24rpx 48rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.empty,
.loading {
  padding: 80rpx 0;
  text-align: center;
  color: var(--color-text-soft);
}
