.promo-hero {
  padding: 36rpx 32rpx;
}

.promo-hero-title {
  display: block;
  margin-top: 14rpx;
  color: var(--color-text);
  font-size: 48rpx;
  font-style: italic;
  font-weight: 700;
  line-height: 1.12;
}

.promo-hero-desc {
  display: block;
  margin-top: 18rpx;
  color: var(--color-text-soft);
  font-size: 24rpx;
  line-height: 1.8;
}

.promo-grid,
.doc-list,
.route-list,
.archive-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.promo-feature-image,
.archive-image {
  width: 100%;
  height: 280rpx;
}

.promo-feature-body,
.archive-body {
  padding: 24rpx;
}

.promo-feature-title,
.doc-item-title,
.route-title,
.archive-title {
  display: block;
  margin-top: 12rpx;
  color: var(--color-text);
  font-size: 34rpx;
  font-style: italic;
  font-weight: 700;
}

.promo-feature-desc,
.doc-item-desc,
.route-desc,
.archive-brief {
  display: block;
  margin-top: 10rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
  line-height: 1.7;
}

.doc-item {
  display: flex;
  align-items: stretch;
}

.doc-item-image {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
}

.doc-item-body {
  flex: 1;
  padding: 22rpx;
}

.doc-item-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.doc-item-tag,
.doc-item-duration,
.route-tag,
.doc-item-link {
  color: var(--color-secondary);
  font-size: 20rpx;
  font-weight: 700;
}

.doc-item-link {
  display: block;
  margin-top: 12rpx;
}

.route-card {
  padding: 26rpx;
}
