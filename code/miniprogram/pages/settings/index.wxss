.settings-list {
  display: flex;
  flex-direction: column;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
  border-bottom: 1rpx solid var(--color-outline);
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-title {
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 700;
}

.settings-title.admin-link {
  color: #d5322a;
}

.settings-arrow {
  color: var(--color-text-soft);
  font-size: 36rpx;
}

.logout-section {
  padding: 40rpx;
}

.logout-btn {
  padding: 28rpx;
  border-radius: 24rpx;
  background: var(--color-surface-card);
  text-align: center;
}

.logout-btn text {
  color: #d5322a;
  font-size: 30rpx;
  font-weight: 700;
}
