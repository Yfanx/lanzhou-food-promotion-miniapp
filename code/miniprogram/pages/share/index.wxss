.composer {
  padding: 28rpx;
}

.composer-title {
  display: block;
  margin-bottom: 16rpx;
  color: var(--color-text);
  font-size: 40rpx;
  font-style: italic;
  font-weight: 700;
}

.composer-input {
  width: 100%;
  min-height: 220rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: var(--color-surface-low);
  color: var(--color-text);
  font-size: 24rpx;
  line-height: 1.8;
}

.composer-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  gap: 16rpx;
}

.composer-count {
  color: var(--color-text-soft);
  font-size: 18rpx;
}

.composer-actions {
  display: flex;
  gap: 12rpx;
}

.composer-ghost,
.composer-primary {
  padding: 18rpx 26rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.composer-ghost {
  background: var(--color-surface-low);
  color: var(--color-text);
}

.composer-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
}

.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 22rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(26, 28, 28, 0.55);
  color: #ffffff;
  text-align: center;
  line-height: 42rpx;
}

.story-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.story-feature-image {
  width: 100%;
  height: 440rpx;
}

.story-feature-body {
  padding: 28rpx;
}

.story-author {
  color: var(--color-primary);
  font-size: 18rpx;
  font-weight: 800;
}

.story-feature-title {
  display: block;
  margin-top: 10rpx;
  color: var(--color-text);
  font-size: 42rpx;
  line-height: 1.15;
  font-style: italic;
  font-weight: 700;
}

.story-feature-brief {
  display: block;
  margin-top: 14rpx;
  color: var(--color-text-soft);
  font-size: 24rpx;
  line-height: 1.7;
}

.story-place {
  display: block;
  margin-top: 20rpx;
  color: var(--color-secondary);
  font-size: 18rpx;
  font-weight: 800;
}

.story-card {
  display: flex;
  overflow: hidden;
}

.story-card-image {
  width: 230rpx;
  height: 210rpx;
  flex-shrink: 0;
}

.story-card-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  padding: 24rpx;
}

.story-card-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-style: italic;
  font-weight: 700;
}

.story-card-brief {
  margin-top: 10rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
  line-height: 1.65;
}

.story-card-foot {
  margin-top: 16rpx;
  color: var(--color-primary);
  font-size: 18rpx;
  font-weight: 800;
}
