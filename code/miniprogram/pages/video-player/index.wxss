.video-hero {
  position: relative;
  height: 520rpx;
  overflow: hidden;
}

.video-hero-image {
  width: 100%;
  height: 100%;
}

.video-hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(26, 28, 28, 0.08) 0%, rgba(26, 28, 28, 0.78) 100%);
}

.video-hero-body {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 30rpx;
}

.video-title {
  display: block;
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 50rpx;
  line-height: 1.12;
  font-style: italic;
  font-weight: 700;
}

.video-brief {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
  line-height: 1.7;
}

.player-card,
.fallback-card {
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 420rpx;
  background: #000000;
}

.fallback-card {
  padding: 30rpx;
}

.fallback-title {
  display: block;
  color: var(--color-text);
  font-size: 34rpx;
  font-weight: 700;
}

.fallback-text {
  display: block;
  margin-top: 14rpx;
  color: var(--color-text-soft);
  font-size: 24rpx;
  line-height: 1.75;
}

.fallback-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-soft));
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.article-card {
  overflow: hidden;
}

.article-image {
  width: 100%;
  height: 260rpx;
}

.article-body {
  padding: 24rpx;
}

.article-title {
  display: block;
  color: var(--color-text);
  font-size: 34rpx;
  font-style: italic;
  font-weight: 700;
}

.article-brief {
  display: block;
  margin-top: 12rpx;
  color: var(--color-text-soft);
  font-size: 22rpx;
  line-height: 1.7;
}

.article-link {
  display: block;
  margin-top: 14rpx;
  color: var(--color-secondary);
  font-size: 20rpx;
  font-weight: 700;
}

.loading {
  padding: 80rpx 0;
  text-align: center;
  color: var(--color-text-soft);
}
